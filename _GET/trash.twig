<!DOCTYPE html>
<html lang="pt-BR">
    <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Etiqueta de Produto 39x39</title>
    {{ default_css() }}

    {% set colunas = 1 %}

    {# Dimensões do driver #}
    {% set larguraEtiqueta = 39 %} 
    {% set alturaEtiqueta = 39 %} 

    {# Reduzido levemente o tamanho do texto para dar mais respiro #}
    {% set tamanhoTextoConteudo = 9.5 %} 

        <style>
            @page {
                size: {{ larguraEtiqueta }}mm {{ alturaEtiqueta }}mm;
                margin: 0;
            }

            body {
                margin: 0;
                padding: 0;
                width: {{ larguraEtiqueta }}mm;
                height: {{ alturaEtiqueta }}mm;
                background-color: #ffffff;
                -webkit-print-color-adjust: exact;
            }

            .etiqueta-container {
                width: 100%;
                height: 100%;
            }

            .etiqueta {
                width: {{ larguraEtiqueta }}mm;
                height: {{ alturaEtiqueta }}mm;
                box-sizing: border-box;
                position: relative; /* Transforma a etiqueta em uma caixinha de referência */
                display: flex;
                flex-direction: column;
                justify-content: center; /* Mantém o preço perfeitamente centralizado no meio */
                align-items: center;
                padding: 0;
                page-break-after: always;
            }

            .texto-superior {
                position: absolute; 
                top: 0.5mm;   
                left: 0.5mm; 
                right: 0.5mm; 
                font-size: {{ tamanhoTextoConteudo }}px;
                line-height: 1.2;
                color: #000000;
                word-break: break-word; 
                overflow-wrap: break-word;
                text-align: left;
            }

            .codigo-destaque {
                font-weight: bold;
                text-transform: uppercase;
            }

            .preco {
                margin-top: 1px;
                font-size: 18px;
                font-weight: bold;
                text-align: center;
                color: #000000;
            }

            .barcode img {
                max-width: 100%;
                text-align: center;
            }
        </style>
    </head>
    <body>

    <div class="etiqueta-container">
    {% for produto in produtos %}
    {% for i in 0..produto.quantidade -1 %}
        <div class="etiqueta">
        
            <div class="texto-superior">
                <span class="codigo-destaque">{{ produto.codigo }}</span>
                {% if produto.nome %} - {{ produto.nome }}{% endif %}
                {% if produto.nomeDerivacao %} - {{ produto.nomeDerivacao }}{% endif %}
            </div>
            <br>
            <div class="preco">
                R$ {{ produto.preco }}
            </div>

            <div class="barcode">
                <img class="barcode-default" src="{{ barcode_src(produto.codigo) }}" alt="Código de barras" style="max-width: auto; max-height: 40%;">
                <span style="display: flex;">{{ produto.ean }}</span>
            </div>
        </div>
    {% endfor %}
    {% endfor %}
    </div>

    </body>
</html>