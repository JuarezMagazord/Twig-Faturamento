{# solicitado na atividade redmine 178221 #}							
{% if calculo_get_parametro_calculado('PARTILHA_ICMS') == 'sim' %}							
{% set base_calculo = calculo_get_parametro_calculado('VLR_BASE_ICMS') %}							
{% set aliquota_fcp = calculo_get_parametro_calculado('ALIQ_FCP_DESTINO') / 100 %}							
	{% set aliquota_icms_destino = calculo_get_parametro_calculado('ALIQ_ICMS_DESTINO') / 100 %}						
	{% set valor_icms_origem = calculo_get_parametro_calculado('VLR_ICMS') %}						
	{% set difal_destino = (100 - calculo_get_parametro_calculado('ALIQ_ICMS_DESTINO')) %}						
	{% set difal_origem = (100 - calculo_get_parametro_calculado('ALIQ_ICMS')) %}						
	{% set base_por_dentro = (base_calculo * difal_origem) %}						
	{% set base_por_dentro = (base_por_dentro  / difal_destino) %}						
							
	{# colocar aqui os estados que fazem o calculo por dentro #}						
	{% if  self.siglaEstado in ['BA','GO','MT', 'MG','PA','PB','PR','PE','RS','SE','TO'] %}						
		{{ self.result(base_por_dentro) }}					
	{% else %}						
		{{ self.result(base_calculo) }}					
	{% endif %}						
{% else %}							
{{ self.result(0.00) }}							
{% endif %}